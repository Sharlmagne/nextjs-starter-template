# Authentication API URL
NEXT_PUBLIC_API_URL=http://localhost:5500/api/v1

# Base API URL
NEXT_PUBLIC_BASE_API_URL=http://localhost:5500

# Public URL for redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Alternative example for ngrok tunneling:
# NEXT_PUBLIC_APP_URL=https://your-ngrok-url.ngrok-free.app

# WebSocket Connection Timeout (milliseconds)
# Production: 60000 (60 seconds) - matches server configuration
# Development: 60000 (60 seconds) - recommended for reliability
# The server expects connections to complete within 60 seconds
NEXT_PUBLIC_SOCKET_TIMEOUT=60000

# WebSocket Logging (development only)
# Set to 'false' to disable socket connection logs in the console
# Default: enabled in development, disabled in production
# NEXT_PUBLIC_SOCKET_LOGGING=false

# Stripe (Public Keys Only - Safe for Client)
# Get from: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Beta mode — shows a "beta" badge on the app logo when set to 'true'
# NEXT_PUBLIC_IS_BETA=true
